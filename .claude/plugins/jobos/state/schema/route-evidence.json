{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RouteEvidence",
  "description": "Evidence collected during route classification for a job",
  "type": "object",
  "required": ["job_id", "classified_at", "route_family", "confidence"],
  "properties": {
    "job_id": { "type": "string" },
    "classified_at": { "type": "string", "format": "date-time" },
    "route_family": {
      "type": "string",
      "enum": ["ats_browser", "board_simplified", "external_redirect", "email", "document_led", "manual"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "url_patterns": { "type": "array", "items": { "type": "string" }, "description": "URL patterns matching known ATS/portal signatures" },
    "page_text_clues": { "type": "array", "items": { "type": "string" }, "description": "Text snippets from the page indicating route type" },
    "email_address": { "type": ["string", "null"], "description": "Email address found for application, if email route" },
    "portal_name": { "type": ["string", "null"], "description": "Detected ATS or portal name (e.g., Workday, Greenhouse, Taleo)" },
    "requires_account": { "type": ["boolean", "null"], "description": "Whether portal requires account creation" },
    "redirect_chain": { "type": "array", "items": { "type": "string" }, "description": "URL redirect chain if external_redirect" },
    "notes": { "type": ["string", "null"] }
  }
}
